{
  "name": "vault-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Vault MCP — thin, no-egress transport over a single Obsidian vault",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "vault-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@vscode/ripgrep": "1.18.0",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "gray-matter": "4.0.3",
    "isomorphic-git": "1.38.4",
    "proper-lockfile": "4.1.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.9.2",
    "@types/proper-lockfile": "4.1.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
