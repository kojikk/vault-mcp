# Copy to .env (gitignored) and set VAULT_HOST_PATH for docker-compose.
# The token itself is NOT an env var in production — it lives in ./secrets/mcp_token
# (a Docker secret). See README/deploy notes.

# Absolute path to the canonical Obsidian vault on the host (Desktop).
VAULT_HOST_PATH=C:\Users\you\ObsidianVault

# --- the variables below are read directly only when running WITHOUT Docker ---
# VAULT_ROOT=C:\Users\you\ObsidianVault
# MCP_TOKEN=        # generate: openssl rand -hex 32   (min 32 chars)
# PORT=8787
# BIND_HOST=127.0.0.1
# LOG_LEVEL=info
